OLLAMA_BASE_URL=http://localhost:11434
LLAMACPP_BASE_URL=http://localhost:8080
LOCAL_BACKEND_MODE=ollama
GITHUB_PAT=your_github_pat_here
SECRET_KEY=AICODEX_SUPER_SECRET_KEY_CHANGEME
# Local dev uses Docker Postgres (started by start_website_dev.bat --aicodex)
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/aicodex
DB_TYPE=sqlite
ALLOWED_COMMANDS=git,python,pip,node,npm,dir,type,cat,ls,mkdir
OLLAMAOPT_PATH=../../OllamaOpt
SEED_ADMIN=True
GCP_PROJECT_ID=your_project_id_here
GCP_REGION=us-central1_or_us-west1_or_etc