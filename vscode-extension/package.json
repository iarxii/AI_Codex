{
  "name": "spirit-bird-aicodex",
  "displayName": "Spirit Bird AICodex",
  "description": "AI-assisted code generation via CodexSpaces.",
  "version": "1.0.0",
  "publisher": "spirit-bird",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages",
    "Machine Learning",
    "AI"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "spirit-bird-sidebar",
          "title": "Spirit Bird",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "spirit-bird-sidebar": [
        {
          "type": "webview",
          "id": "spirit-bird-chat-view",
          "name": "Spirit Bird AI Codex"
        }
      ]
    },
    "commands": [
      {
        "command": "spirit-bird-aicodex.generateCode",
        "title": "Spirit Bird: Generate Code from Comment"
      }
    ],
    "configuration": {
      "title": "Spirit Bird AICodex",
      "properties": {
        "spiritBirdAiCodex.apiKey": {
          "type": "string",
          "default": "",
          "description": "Your AICodex User Authentication JWT Token."
        },
        "spiritBirdAiCodex.endpoint": {
          "type": "string",
          "default": "http://localhost:9000/api",
          "description": "The base API endpoint for AICodex."
        },
        "spiritBirdAiCodex.spaceSlug": {
          "type": "string",
          "default": "code-lab",
          "description": "The CodexSpace slug to use for code generation (e.g., code-lab, spirit-book)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.1.3"
  }
}
